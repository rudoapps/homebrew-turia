#!/bin/bash

# Detectar si se usa --json antes de mostrar cualquier output
JSON_OUTPUT="false"
for arg in "$@"; do
  if [ "$arg" = "--json" ]; then
    JSON_OUTPUT="true"
    break
  fi
done
export JSON_OUTPUT

