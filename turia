# Procesar los argumentos
COMMAND="$1"
# Manejar --help como primer argumento
if [[ "$COMMAND" == "--help" || "$COMMAND" == "-h" ]]; then
  COMMAND="help"
fi

# Manejar caso especial: turia template --list
if [[ "$COMMAND" == "template" && "${2:-}" == "--list" ]]; then
  LIST_TEMPLATES="true"
  MODULE_NAME=""
elif [[ "$COMMAND" == "template" && -n "${2:-}" && "${2:-}" != "--list" ]]; then
  MODULE_NAME="${2:-}"
fi

# Manejar caso especial: turia validate --staged
VALIDATE_STAGED="false"
if [[ "$COMMAND" == "validate" && "${2:-}" == "--staged" ]]; then
  VALIDATE_STAGED="true"
fi

# Manejar comando 'ai' — cliente Python
# `turia skills ...` es un alias de `turia ai --skills ...` para operaciones
# de marketplace/packs sin entrar al REPL.
if [[ "$COMMAND" == "ai" || "$COMMAND" == "skills" ]]; then
  _turia_skills_prefix=()
  if [[ "$COMMAND" == "skills" ]]; then
    _turia_skills_prefix=(--skills)
  fi
  shift  # Remove command from args

  # Disable EXIT trap immediately — we don't want cleanup_on_exit firing
  # silently when something goes wrong in this code path.
  trap - EXIT

  if [[ "$COMMAND" == "ai" ]]; then
    echo -e "  ${DIM}[turia] iniciando agente...${NC}" >&2
  fi

  # ── Resolve best Python (3.10+) ──────────────────────────────────
  # Prefer Homebrew's python@3.12 (declared as a formula dependency,
  # so it's guaranteed to exist on installs via brew). Fall back to
  # any other Python 3.10+ on PATH if for some reason it's missing.
  _turia_python=""
  _brew_py_paths=(
    "$HOMEBREW_PREFIX/opt/python@3.12/bin/python3.12"
    "$HOMEBREW_PREFIX/opt/python@3.12/libexec/bin/python3"
    "$HOMEBREW_PREFIX/bin/python3.12"
    "/opt/homebrew/opt/python@3.12/bin/python3.12"
    "/home/linuxbrew/.linuxbrew/opt/python@3.12/bin/python3.12"
  )
  for _bp in "${_brew_py_paths[@]}"; do
    if [ -x "$_bp" ]; then
      _turia_python="$_bp"
      break
    fi
  done

  # Fallback: scan PATH for any python 3.10+
  if [ -z "$_turia_python" ]; then
    for _candidate in python3.13 python3.12 python3.11 python3.10 python3; do
      _path=$(command -v "$_candidate" 2>/dev/null)
      if [ -n "$_path" ]; then
        _ver=$("$_path" -c "import sys; print(sys.version_info[:2] >= (3,10))" 2>/dev/null)
        if [ "$_ver" = "True" ]; then
          _turia_python="$_path"
          break
        fi
      fi
    done
  fi

  # Last-resort: common system paths
  if [ -z "$_turia_python" ]; then
    for _bp in /opt/homebrew/bin/python3 /usr/local/bin/python3 /usr/bin/python3; do
      if [ -x "$_bp" ]; then
        _ver=$("$_bp" -c "import sys; print(sys.version_info[:2] >= (3,10))" 2>/dev/null)
        if [ "$_ver" = "True" ]; then
          _turia_python="$_bp"
          break
        fi
      fi
    done
  fi

  if [ -z "$_turia_python" ]; then
    echo -e "${RED}Error: Se requiere Python 3.10 o superior.${NC}"
    echo -e "Instala con: ${BOLD}brew install python@3.12${NC}"
    exit 1
  fi
  echo -e "  ${DIM}[turia] python detectado: $_turia_python${NC}" >&2

  # ── Ensure venv with dependencies ─────────────────────────────────
  # ⚠️  BUMP THIS NUMBER when adding/changing Python dependencies.
  # The venv is deleted and recreated when this changes.
  # Without bumping, existing users keep the old venv and miss new deps.
  _TURIA_DEPS_VERSION="3"
  _turia_venv="$HOME/.config/turia-agent/venv"
  _turia_deps_stamp="$_turia_venv/.deps_version"

  _needs_venv=false
  if [ ! -f "$_turia_venv/bin/python" ]; then
    _needs_venv=true
  elif [ ! -f "$_turia_deps_stamp" ] || [ "$(cat "$_turia_deps_stamp" 2>/dev/null)" != "$_TURIA_DEPS_VERSION" ]; then
    echo -e "  ${DIM}Actualizando entorno Python...${NC}"
    rm -rf "$_turia_venv"
    _needs_venv=true
  else
    # Validate the existing venv's Python version is 3.10+
    _venv_py_ok=$("$_turia_venv/bin/python" -c "import sys; print(sys.version_info[:2] >= (3,10))" 2>/dev/null)
    if [ "$_venv_py_ok" != "True" ]; then
      _venv_py_ver=$("$_turia_venv/bin/python" -c "import sys; print('%d.%d' % sys.version_info[:2])" 2>/dev/null || echo "?")
      echo -e "  ${YELLOW}Venv existente usa Python $_venv_py_ver, se requiere 3.10+. Recreando...${NC}"
      rm -rf "$_turia_venv"
      _needs_venv=true
    fi
  fi

  if [ "$_needs_venv" = true ]; then
    echo -e "  ${DIM}Creando entorno Python para turia ai...${NC}"
    "$_turia_python" -m venv "$_turia_venv" || {
      echo -e "${RED}Error: No se pudo crear el entorno virtual.${NC}"
      exit 1
    }
    "$_turia_venv/bin/pip" install --quiet --upgrade pip 2>/dev/null
    "$_turia_venv/bin/pip" install --quiet httpx rich prompt-toolkit pyyaml || {
      echo -e "${RED}Error: No se pudieron instalar las dependencias.${NC}"
      rm -rf "$_turia_venv"
      exit 1
    }
    echo "$_TURIA_DEPS_VERSION" > "$_turia_deps_stamp"
    echo -e "  ${GREEN}✓${NC} Entorno Python configurado"
  fi

  # Quick check: verify python+core deps are importable, reinstall if broken
  _venv_check_err=$("$_turia_venv/bin/python" -c "import httpx, rich, prompt_toolkit, yaml" 2>&1)
  if [ -n "$_venv_check_err" ]; then
    echo -e "  ${DIM}Reparando dependencias...${NC}"
    if [ -n "$_venv_check_err" ]; then
      echo -e "  ${DIM}(motivo: $(echo "$_venv_check_err" | tail -1))${NC}"
    fi
    "$_turia_venv/bin/pip" install --quiet --force-reinstall httpx rich prompt-toolkit pyyaml || {
      echo -e "${RED}Error: No se pudieron reparar las dependencias.${NC}"
      echo -e "${YELLOW}Intenta: rm -rf '$_turia_venv' && turia ai${NC}"
      exit 1
    }
    echo -e "  ${GREEN}✓${NC} Dependencias reparadas"
  fi

  # Auto-install LSP server if needed (silent if already installed)
  _lsp_pkg=$("$_turia_venv/bin/python" -c "
import sys; sys.path.insert(0, '${scripts_dir}/agent')
from turia_chat.driven.lsp.lsp_server_registry import get_pip_package
from turia_chat.driven.context.project_context_builder import ProjectContextBuilder
pt = ProjectContextBuilder().detect_project_type()
pkg = get_pip_package(pt) if pt else None
print(pkg or '')
" 2>/dev/null)
  if [ -n "$_lsp_pkg" ]; then
    echo -e "  ${DIM}Instalando LSP: $_lsp_pkg...${NC}"
    "$_turia_venv/bin/pip" install --quiet "$_lsp_pkg" 2>/dev/null && \
      echo -e "  ${GREEN}✓${NC} LSP instalado" || true
  fi

  echo -e "  ${DIM}[turia] python=$_turia_venv/bin/python${NC}" >&2

  # Run python WITHOUT exec so we can detect silent exits and surface
  # the exit code. exec on WSL has been observed to swallow startup errors.
  PYTHONPATH="${scripts_dir}/agent" "$_turia_venv/bin/python" -m turia_chat "${_turia_skills_prefix[@]}" "$@"
  _turia_rc=$?

  if [ $_turia_rc -ne 0 ]; then
    echo -e "${RED}[turia] turia_chat termino con codigo $_turia_rc${NC}" >&2
    echo -e "${YELLOW}Si esto persiste, prueba: rm -rf '$_turia_venv' && turia ai${NC}" >&2
  fi
  exit $_turia_rc
fi

# Manejar comandos del agente AI directamente: turia chat, turia login, turia setup
if [[ "$COMMAND" == "chat" || "$COMMAND" == "login" || "$COMMAND" == "setup" || "$COMMAND" == "logout" || "$COMMAND" == "whoami" ]]; then
  # Check if --help is requested
  if [[ "${2:-}" == "--help" || "${2:-}" == "-h" ]]; then
    agent_command "help"
    exit $?
  fi
  shift  # Remove the command from args
  agent_command "$COMMAND" "$@"
  exit $?
fi

# Mantener compatibilidad con: turia agent <subcommand> [args]
if [[ "$COMMAND" == "agent" ]]; then
  AGENT_SUBCOMMAND="${2:---help}"
  # Normalize --help to help
  if [[ "$AGENT_SUBCOMMAND" == "--help" || "$AGENT_SUBCOMMAND" == "-h" ]]; then
    AGENT_SUBCOMMAND="help"
  fi
  shift 2 2>/dev/null || shift
  # Skip the while loop for agent commands - pass remaining args properly quoted
  agent_command "$AGENT_SUBCOMMAND" "$@"
  exit $?
fi

shift

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --key=*)
      KEY="${1#*=}"
      ;;
    --branch=*)
      BRANCH="${1#*=}"
      ;;
    --type=*)
      TEMPLATE_TYPE="${1#*=}"
      ;;
    --archetype=*)
      ARCHETYPE_TYPE="${1#*=}"
      ;;
    --json)
      JSON_OUTPUT="true"
      ;;
    --force)
      FORCE_INSTALL="true"
      export FORCE_INSTALL
      ;;
    --integrate)
      INTEGRATE_MODE="true"
      INSTALL_MODE_SELECTED="true"
      export INTEGRATE_MODE
      export INSTALL_MODE_SELECTED
      ;;
    --module)
      INTEGRATE_MODE="false"
      INSTALL_MODE_SELECTED="true"
      export INTEGRATE_MODE
      export INSTALL_MODE_SELECTED
      ;;
    --list)
      LIST_TEMPLATES="true"
      ;;
    --bb-user=*)
      BB_USER="${1#*=}"
      ;;
    --bb-token=*)
      BB_TOKEN="${1#*=}"
      ;;
    --bb-workspace=*)
      BB_WORKSPACE="${1#*=}"
      ;;
    --bb-repo=*)
      BB_REPO="${1#*=}"
      ;;
    --bb-public)
      BB_PRIVATE="false"
      ;;
    --help|-h)
      COMMAND="help"
      ;;
    install)
      COMMAND="install"
      if [ -n "${2:-}" ]; then
        # Detectar si hay múltiples módulos separados por comas
        if [[ "$2" == *","* ]]; then
          # Modo batch: convertir string "mod1,mod2,mod3" a array
          IFS=',' read -ra MODULE_NAMES <<< "$2"
          BATCH_MODE="true"
        else
          # Modo individual
          MODULE_NAME="$2"
          BATCH_MODE="false"
        fi
        shift
      fi
      ;;
    list)
      COMMAND="list"
      ;;
    branches)
      COMMAND="branches"
      ;;
    status)
      COMMAND="status"
      ;;
    validate)
      COMMAND="validate"
      ;;
    install-hook)
      COMMAND="install-hook"
      ;;
    help)
      COMMAND="help"
      ;;
    create)
      COMMAND="create"
      if [ -n "${2:-}" ]; then
        MODULE_NAME="$2"
        shift
      fi
      ;;
    template)
      COMMAND="template"
      MODULE_NAME="${2:-}"
      shift
      ;;
    agent)
      COMMAND="agent"
      AGENT_SUBCOMMAND="${2:-help}"
      AGENT_ARGS="${@:3}"
      break  # Stop processing more arguments - agent handles its own
      ;;
    *)
      MODULE_NAME="$1"
      ;;
  esac
  shift
done  

# Limpiar directorio temporal antes de ejecutar cualquier comando
cleanup_temp_directory

if [ "$COMMAND" == "install" ]; then
  if [ -z "$MODULE_NAME" ]; then
    echo "Uso: $0 install <module_name> [--key=xxxx]"
    exit 1
  fi
  install_module "$MODULE_NAME"
elif [ "$COMMAND" == "list" ]; then
  list_modules
elif [ "$COMMAND" == "help" ]; then
  show_help
elif [ "$COMMAND" == "template" ]; then
  if [ "$LIST_TEMPLATES" == "true" ]; then
    list_templates
  elif [ -z "$MODULE_NAME" ]; then
    echo "Uso: $0 template <module_name> [--type=clean] [--list]"
    exit 1
  else
    install_template "$MODULE_NAME"
  fi
elif [ "$COMMAND" == "create" ]; then
  if [ -z "$MODULE_NAME" ]; then
    echo "Uso: $0 create <platform {ios}>"
    exit 1
  fi
  create_project "$MODULE_NAME"

  # Post-create: configurar repo en Bitbucket si se pasaron los flags
  if [ -n "$BB_TOKEN" ]; then
    if [ -z "$BB_USER" ] || [ -z "$BB_WORKSPACE" ]; then
      echo -e "${RED}Error: Se requieren --bb-user y --bb-workspace para crear el repo en Bitbucket.${NC}"
      echo "Uso: turia create <platform> --key=XXX --bb-user=usuario --bb-token=YYY --bb-workspace=mi_workspace [--bb-repo=nombre_repo]"
      exit 1
    fi

    # Determinar el directorio del proyecto creado
    # Cada plataforma usa distinta variable: projectPath (ios/python), PROJECT_PATH (android/flutter)
    CREATED_PROJECT_DIR="${projectPath:-${PROJECT_PATH:-}}"

    if [ -z "$CREATED_PROJECT_DIR" ] || [ ! -d "$CREATED_PROJECT_DIR" ]; then
      echo -e "${RED}Error: No se pudo determinar el directorio del proyecto creado.${NC}"
      exit 1
    fi

    # Si no se especificó nombre de repo, usar el nombre del proyecto
    if [ -z "$BB_REPO" ]; then
      BB_REPO=$(basename "$CREATED_PROJECT_DIR")
    fi

    # Normalizar nombre del repo (lowercase, sin espacios)
    BB_REPO=$(echo "$BB_REPO" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

    # Guardar directorio actual y entrar al proyecto
    ORIGINAL_DIR="$PWD"
    cd "$CREATED_PROJECT_DIR"

    setup_bitbucket_repo "$BB_USER" "$BB_TOKEN" "$BB_WORKSPACE" "$BB_REPO" "$BB_PRIVATE"

    # Volver al directorio original
    cd "$ORIGINAL_DIR"
  fi
elif [ "$COMMAND" == "branches" ]; then
  if [ -z "$KEY" ]; then
    if [ "$JSON_OUTPUT" = "true" ]; then
      echo "{\"status\":\"error\",\"message\":\"KEY requerida\"}"
    else
      echo "Uso: $0 branches --key=xxxx [--archetype=<platform>] [--json]"
      echo "Plataformas válidas para archetype: android, ios, flutter, python"
    fi
    exit 1
  fi

  # Determinar formato de salida
  output_format="normal"
  if [ "$JSON_OUTPUT" = "true" ]; then
    output_format="json"
  fi

  if [ -n "$ARCHETYPE_TYPE" ]; then
    # Consultar ramas de arquetipos
    get_access_token "$KEY" "$ARCHETYPE_TYPE"
    list_branches "archetype-$ARCHETYPE_TYPE" "$output_format"
  else
    # Detectar automáticamente el tipo de proyecto
    if check_type_of_project; then
      type=0
    else
      type=$?
    fi

    case "$type" in
      0)
        if [ "$JSON_OUTPUT" != "true" ]; then
          echo -e "${GREEN}Detectado proyecto Android${NC}"
        fi
        get_access_token "$KEY" "android"
        list_branches "android" "$output_format"
        ;;
      1)
        if [ "$JSON_OUTPUT" != "true" ]; then
          echo -e "${GREEN}Detectado proyecto iOS${NC}"
        fi
        get_access_token "$KEY" "ios"
        list_branches "ios" "$output_format"
        ;;
      2)
        if [ "$JSON_OUTPUT" != "true" ]; then
          echo -e "${GREEN}Detectado proyecto Flutter${NC}"
        fi
        get_access_token "$KEY" "flutter"
        list_branches "flutter" "$output_format"
        ;;
      3)
        if [ "$JSON_OUTPUT" != "true" ]; then
          echo -e "${GREEN}Detectado proyecto Python${NC}"
        fi
        get_access_token "$KEY" "back"
        list_branches "python" "$output_format"
        ;;
      *)
        if [ "$JSON_OUTPUT" = "true" ]; then
          echo "{\"status\":\"error\",\"message\":\"No se detectó un tipo de proyecto válido\"}"
        else
          echo -e "${RED}Error: No se detectó un tipo de proyecto válido.${NC}"
          echo "Si quieres consultar ramas de arquetipos usa: $0 branches --key=xxxx --archetype=<platform>"
        fi
        exit 1
        ;;
    esac
  fi
elif [ "$COMMAND" == "status" ]; then
  show_project_status
elif [ "$COMMAND" == "validate" ]; then
  if [ "$VALIDATE_STAGED" == "true" ]; then
    validate_staged_configurations
  else
    validate_configuration_files
  fi
elif [ "$COMMAND" == "install-hook" ]; then
  install_validation_hook
else
  echo "Comando no reconocido. Uso: $0 {ai|chat|login|setup|logout|whoami|install|list|template|create|branches|status|validate|help} [opciones]"
  echo "Usa '$0 --help' para obtener ayuda detallada."
  exit 1
fi